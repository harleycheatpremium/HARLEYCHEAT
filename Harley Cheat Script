-- Harley Cheat | Premium Block Spin Hub
local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

local Window = Rayfield:CreateWindow({
    Name = "Harley Premium | Block Spin",
    LoadingTitle = "Harley Engine Loading...",
    LoadingSubtitle = "by Swoxy",
    Theme = "Amethyst",
})

local MainTab = Window:CreateTab("Main", 4483362458)

-- ESP Toggle
MainTab:CreateToggle({
    Name = "ESP (Highlight)",
    CurrentValue = false,
    Flag = "ESP",
    Callback = function(Value)
        for _, v in pairs(game.Players:GetPlayers()) do
            if v ~= game.Players.LocalPlayer and v.Character then
                local highlight = v.Character:FindFirstChild("Highlight") or Instance.new("Highlight", v.Character)
                highlight.Enabled = Value
                highlight.FillColor = Color3.fromRGB(255, 0, 0)
            end
        end
    end,
})

-- WalkSpeed Slider
MainTab:CreateSlider({
    Name = "WalkSpeed",
    Range = {16, 100},
    Increment = 1,
    Suffix = " Speed",
    CurrentValue = 16,
    Callback = function(Value)
        game.Players.LocalPlayer.Character.Humanoid.WalkSpeed = Value
    end,
})

Rayfield:LoadConfiguration()
