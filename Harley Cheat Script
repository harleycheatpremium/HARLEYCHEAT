-- Harley Cheat | Premium Blockspin Hub
local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

local Window = Rayfield:CreateWindow({
    Name = "Harley Cheat | Premium",
    LoadingTitle = "Bypassing Security...",
    LoadingSubtitle = "by Swoxy",
    Theme = "Amethyst",
})

local Tab = Window:CreateTab("Main", 4483362458)

-- Özellik Değişkenleri
getgenv().SilentAim = false
getgenv().ESP = false

-- Silent Aim Toggle
Tab:CreateToggle({
    Name = "Silent Aim",
    CurrentValue = false,
    Flag = "SilentAim",
    Callback = function(Value)
        getgenv().SilentAim = Value
        if Value then
            print("Silent Aim Aktif")
        end
    end,
})

-- ESP Toggle
Tab:CreateToggle({
    Name = "ESP (Wallhack)",
    CurrentValue = false,
    Flag = "ESP",
    Callback = function(Value)
        getgenv().ESP = Value
        if Value then
            -- ESP için basit bir highlight ekleme
            for _, v in pairs(game.Players:GetPlayers()) do
                if v ~= game.Players.LocalPlayer then
                    local highlight = Instance.new("Highlight", v.Character)
                    highlight.FillColor = Color3.fromRGB(255, 0, 0)
                end
            end
        end
    end,
})

-- Bilgi Butonu
Tab:CreateButton({
    Name = "Konsolu Temizle",
    Callback = function()
        rconsoleclear()
    end,
})

Rayfield:LoadConfiguration()
