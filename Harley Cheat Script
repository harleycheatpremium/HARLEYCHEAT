local LocalPlayer = Players.LocalPlayer

-- // CORE ENGINE SETTINGS
local Engine = {
    Settings = {
        SilentAim = false,
        ESP = false,
        Speed = 16
    }
}

-- // BYPASS SYSTEM (Anti-Cheat Security Layer)
local function BypassSecurity()
    local mt = getrawmetatable(game)
    setreadonly(mt, false)
    local oldNamecall = mt.__namecall
    
    mt.__namecall = newcclosure(function(self, ...)
        local method = getnamecallmethod()
        -- Intercepting security probes
        if tostring(self):lower():find("anticheat") or tostring(self):lower():find("check") then
            return nil
        end
        return oldNamecall(self, ...)
    end)
    setreadonly(mt, true)
end
BypassSecurity()

-- // UI SETUP
local Window = OrionLib:MakeWindow({
    Name = "GODZILLA ENGINE | HARLEY EDITION",
    HidePremium = false,
    SaveConfig = true,
    ConfigFolder = "HarleyEngine"
})

-- // TABS
local Tab_Combat = Window:MakeTab({Name = "Combat Core", Icon = "rbxassetid://4483345998"})
local Tab_Visuals = Window:MakeTab({Name = "Visual Engine", Icon = "rbxassetid://4483345998"})
local Tab_Utility = Window:MakeTab({Name = "World God Mode", Icon = "rbxassetid://4483345998"})

-- // COMBAT SECTION
Tab_Combat:AddToggle({
    Name = "Silent Aim (Bullet Track)",
    Default = false,
    Callback = function(Value)
        Engine.Settings.SilentAim = Value
    end
})

-- // VISUALS SECTION
Tab_Visuals:AddToggle({
    Name = "ESP Box (Players)",
    Default = false,
    Callback = function(Value)
        Engine.Settings.ESP = Value
        for _, v in pairs(Players:GetPlayers()) do
            if v ~= LocalPlayer and v.Character then
                local h = v.Character:FindFirstChild("Highlight") or Instance.new("Highlight", v.Character)
                h.Enabled = Value
                h.FillColor = Color3.fromRGB(0, 255, 255)
            end
        end
    end
})

-- // UTILITY SECTION
Tab_Utility:AddSlider({
    Name = "WalkSpeed Modifier",
    Min = 16, Max = 45, Default = 16,
    Callback = function(Value)
        LocalPlayer.Character.Humanoid.WalkSpeed = Value
    end
})

